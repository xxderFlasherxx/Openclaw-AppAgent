{
  "paths": {
    "projectsRoot": "/home/vboxuser/GameDev-Projekte",
    "openclawWorkspace": "/home/vboxuser/Documents/Openclaw-AppAgent/workspace",
    "templatesDir": "/home/vboxuser/GameDev-Projekte/_templates",
    "unityEditor": "",
    "vscode": "code"
  },
  "unity": {
    "version": "2022.3",
    "renderPipeline": "URP",
    "buildTarget": "StandaloneLinux64",
    "batchModeFlags": "-batchmode -nographics -quit",
    "mode": "auto",
    "editorBinary": "",
    "batchLogFile": ".plan/unity-batch.log",
    "statusFile": ".plan/unity-status.json",
    "errorLogFile": ".plan/error-log.jsonl",
    "compileTimeoutSeconds": 180
  },
  "models": {
    "architect": "qwen3-coder-next",
    "coderDefault": "claude-sonnet-4.6",
    "coderComplex": "claude-opus",
    "coderQuick": "claude-haiku"
  },
  "ollamaCloud": {
    "baseUrl": "https://ollama.com/v1",
    "model": "qwen3-coder-next:cloud",
    "temperature": 0.3,
    "maxTokens": 8192
  },
  "phases": {
    "maxPhases": 10,
    "maxRetriesPerPhase": 5,
    "timeoutPerPhaseSeconds": 300,
    "pollingIntervalSeconds": 3,
    "copilotWaitSeconds": 60,
    "compileWaitSeconds": 120
  },
  "automation": {
    "method": "file-based",
    "fallbackMethod": "xdotool",
    "autoStart": false,
    "notifyOnPhaseComplete": true,
    "notifyOnError": true
  },
  "modelRouting": {
    "enabled": true,
    "escalateAtRetry": 3,
    "defaultModel": "sonnet",
    "overrides": {
      "1": "haiku",
      "10": "haiku"
    },
    "categoryMap": {
      "structure": "haiku",
      "setup": "haiku",
      "config": "haiku",
      "template": "haiku",
      "editor": "haiku",
      "build": "haiku",
      "ui": "sonnet",
      "menu": "sonnet",
      "gamelogic": "sonnet",
      "physics": "opus",
      "procedural": "opus",
      "ai": "opus",
      "shader": "opus",
      "optimization": "opus"
    },
    "keywords": {
      "haiku": [
        "structure", "setup", "config", "template", "boilerplate",
        "folder", "gitignore", "editorconfig", "asmdef",
        "editor script", "editor window", "menu item",
        "scene bootstrapper", "file creation", "readme"
      ],
      "sonnet": [
        "ui", "hud", "menu", "settings", "options", "pause",
        "inventory view", "input", "controller", "movement",
        "camera follow", "audio manager", "score", "health",
        "timer", "gamemanager", "dialogue", "save", "load"
      ],
      "opus": [
        "physics", "rigidbody", "wheelcollider", "joint", "ragdoll",
        "procedural", "noise", "perlin", "generation", "terrain",
        "ai", "pathfinding", "navmesh", "behavior tree",
        "shader", "material", "urp", "post processing",
        "optimization", "multithread", "jobs", "burst",
        "netcode", "networking", "multiplayer"
      ]
    },
    "pricing": {
      "haiku":  { "inputPer1K": 0.00025, "outputPer1K": 0.00125 },
      "sonnet": { "inputPer1K": 0.003,   "outputPer1K": 0.015   },
      "opus":   { "inputPer1K": 0.015,   "outputPer1K": 0.075   }
    }
  },
  "memory": {
    "enabled": true,
    "projectsFile": "/home/vboxuser/.openclaw/workspace/memory/gamedev-projects.json",
    "patternsFile": "/home/vboxuser/.openclaw/workspace/memory/gamedev-patterns.json",
    "archiveFile":  "/home/vboxuser/.openclaw/workspace/memory/gamedev-projects-archive.json",
    "lockFile":     "/home/vboxuser/.openclaw/workspace/memory/.memory.lock",
    "maxProjectsInMemory": 100,
    "minPatternSuccessRate": 0.3,
    "patternUseThreshold": 2,
    "schemaVersion": 1
  },
  "feedback": {
    "enabled": true,
    "timeoutHours": 24,
    "askDetailsBelowRating": 3,
    "askDetailsAboveRating": 4,
    "saveFreeText": true,
    "promptHintsFile": "templates/feedback-prompt-hints.json"
  },
  "copilotBridge": {
    "preferredAdapter": "file-injection",
    "fallbackChain": ["file-injection", "gh-copilot-cli", "ui-automation"],
    "vscodeWorkspacePath": null,
    "taskName": "copilot-run-phase",
    "uiAutomation": {
      "enabled": false,
      "tool": "xdotool",
      "display": ":0",
      "typingDelayMs": 25
    },
    "timeoutSeconds": 180,
    "pollIntervalSeconds": 3
  },
  "codeExtraction": {
    "stripMarkdownFences": true,
    "stripPreambles": true,
    "requireBalancedBraces": true,
    "maxFileSizeKb": 200,
    "diffDir": ".plan/copilot-diffs",
    "forbiddenTokens": [
      "TODO-COPILOT",
      "PLACEHOLDER",
      "<PROMPT>",
      "your code here",
      "implementiere dies",
      "// ... rest of code",
      "...existing code..."
    ]
  },
  "safety": {
    "writeScope": [
      "~/GameDev-Projekte/<projectName>/**",
      "~/.openclaw/workspace/memory/gamedev-*.json"
    ],
    "denyScope": [
      "~/.ssh/**",
      "/etc/**",
      "/usr/**",
      "~/.config/**",
      "~/.openclaw/openclaw.json"
    ],
    "approvalMode": "auto-with-telegram-veto",
    "vetoWindowSeconds": 20,
    "maxFilesChangedPerPhase": 15,
    "maxBytesPerFile": 204800,
    "dryRunFirstRun": true
  },
  "dryRun": false
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Halt-Log Entry",
  "type": "object",
  "required": ["ts", "runId", "reason", "value", "phase", "state"],
  "properties": {
    "ts":     { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T" },
    "runId":  { "type": "string", "minLength": 1 },
    "reason": {
      "type": "string",
      "enum": [
        "killswitch",
        "budget_exhausted_run",
        "budget_exhausted_phase",
        "wallclock_exceeded",
        "retries_exhausted",
        "manual_abort",
        "safety_violation",
        "tick_exception"
      ]
    },
    "value":  { "type": ["number", "string", "null"] },
    "phase":  { "type": ["integer", "null"], "minimum": 0, "maximum": 10 },
    "state":  { "type": "string" }
  }
}

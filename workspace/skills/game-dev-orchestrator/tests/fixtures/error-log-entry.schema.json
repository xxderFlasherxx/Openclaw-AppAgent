{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ErrorLogJsonlEntry",
  "description": "Eine Zeile aus .plan/error-log.jsonl (NDJSON). Wird vom AutoCompileWatcher und vom Batchmode-Fallback erzeugt.",
  "type": "object",
  "required": ["timestamp", "type", "message"],
  "additionalProperties": true,
  "properties": {
    "timestamp":  { "type": "string", "minLength": 1 },
    "phaseId":    { "type": ["integer", "null"] },
    "project":    { "type": ["string", "null"] },
    "type":       { "type": "string", "enum": ["Error", "Exception", "Warning"] },
    "message":    { "type": "string" },
    "stackTrace": { "type": "string" },
    "file":       { "type": "string" },
    "line":       { "type": "integer", "minimum": 0 }
  }
}
